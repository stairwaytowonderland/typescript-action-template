{
	"github.copilot.chat.reviewSelection.instructions": [
		{
			"text": "Review the code changes carefully before accepting them."
		}
	],
	"github.copilot.chat.commitMessageGeneration.instructions": [
		{
			"text": "Use conventional commit message format."
		}
	],
	"github.copilot.chat.pullRequestDescriptionGeneration.instructions": [
		{ "text": "Always include a list of key changes." }
	],

	/*
		Editor settings
	*/
	"editor.formatOnSave": true,
	"editor.formatOnType": false,
	"editor.formatOnPaste": false,
	// https://marketplace.visualstudio.com/items?itemName=esbenp.prettier-vscode
	"editor.defaultFormatter": "esbenp.prettier-vscode",
	"editor.detectIndentation": false,
	"editor.tabSize": 4,
	"editor.renderWhitespace": "boundary",
	"editor.codeActionsOnSave": {
		"source.fixAll": "explicit"
	},

	/*
		Prettier settings
	*/
	"prettier.useEditorConfig": true,
	"prettier.configPath": ".prettierrc",

	/*
		Files settings
	*/
	"files.eol": "\n",
	"files.encoding": "utf8",
	"files.trimTrailingWhitespace": true,
	"files.insertFinalNewline": true,
	"files.associations": {
		"*.Brewfile": "ruby",
		"*.cron": "shellscript",
		"*.lib": "shellscript",
		"*yaml.tftpl": "jinja-yaml",
		"*json.tftpl": "jinja-json",
		"LICENSE": "plaintext",
		"CODEOWNERS": "properties"
	},
	"files.exclude": {
		"**/.git": true,
		"**/.DS_Store": true,
		"**/node_modules": true,
		"**/dist": true,
		"**/build": true,
		"**/__pycache__": true,
		"**/.venv": true,
		"**/*.tfstate": true,
		"**/*.tfstate.*": true,
		"**/.terraform": true,
		".terraform.lock.hcl": true
	},

	/*
		Terminal settings
	*/
	"terminal.integrated.defaultProfile.osx": "bash",
	"terminal.integrated.profiles.osx": {
		"bash": {
			"path": "${env:SHELL}",
			"icon": "terminal",
			"color": "terminal.ansiGreen"
		},
		"sh": {
			"path": "/bin/sh",
			"icon": "terminal-linux",
			"color": "terminal.ansiYellow",
			"overrideName": true
		}
	},

	/*
		Git settings
	*/
	"git.autofetch": true,
	"git.enableSmartCommit": true,
	"git.confirmSync": false,

	/*
		YAML settings
		Leave commented to use prettier for YAML formatting instead of redhat.vscode-yaml -- recommended to avoid conflicts between formatters
	*/
	// "[yaml]": {
	// 	"editor.defaultFormatter": "redhat.vscode-yaml",
	// 	"editor.formatOnSave": true
	// },

	/*
		Markdown settings
	*/
	"[markdown]": {
		"editor.defaultFormatter": "yzhang.markdown-all-in-one",
		"editor.formatOnSave": true,
		"editor.formatOnPaste": true,
		"editor.codeActionsOnSave": {
			"source.fixAll.markdownlint": "explicit"
		}
	},
	// https://github.com/yzhang-gh/vscode-markdown?tab=readme-ov-file#supported-settings
	"markdown.extension.orderedList.marker": "one",
	"markdown.extension.toc.unorderedList.marker": "-",
	"markdown.extension.list.indentationSize": "adaptive",

	/*
		Shellcheck settings
	*/
	"shellcheck.customArgs": ["-x"],

	/*
		Shellscript settings
	*/
	// "[shellscript]": {
	// 	"editor.defaultFormatter": "mkhl.shfmt",
	// 	"editor.formatOnSave": true
	// },

	/*
		Dockerfile settings
	*/
	// "[dockerfile]": {
	// 	"editor.defaultFormatter": "ms-azuretools.vscode-containers",
	// 	"editor.formatOnSave": false
	// },

	/*
		Terraform settings
	*/
	// "terraform.experimentalFeatures.validateOnSave": true,
	// "[terraform]": {
	// 	"editor.defaultFormatter": "hashicorp.terraform",
	// 	"editor.formatOnSave": true,
	// 	"editor.tabSize": 2
	// },
	// "[terraform-vars]": {
	// 	"editor.defaultFormatter": "hashicorp.terraform",
	// 	"editor.formatOnSave": true,
	// 	"editor.tabSize": 2
	// },

	/*
		Configuration Language settings
	*/
	"[toml]": {
		"editor.defaultFormatter": "tamasfe.even-better-toml",
		"editor.formatOnSave": true
	}

	/*
		Python settings
		# If formatting isn't working after changing black-formatter.args ...
		# In the Command Palette search for 'Black Formatter: Restart Server'

		# Sample pyproject.toml
		[tool.black]
		line-length = 88
		target-version = ['py310', 'py311', 'py312']
		include = '\.pyi?$'
	*/
	// "black-formatter.args": ["--config", "${workspaceFolder}/pyproject.toml"],
